# Anthropic
ANTHROPIC_API_KEY=

# Swiggy OAuth (from Swiggy Builders Club — required for Connect with Swiggy)
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=
SWIGGY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Dev-only override: skip OAuth and test MCP with a raw Bearer token
SWIGGY_ACCESS_TOKEN=

# Session encryption (required — min 32 random characters)
SESSION_SECRET=

# App base URL (used for OAuth redirects)
NEXTAUTH_URL=http://localhost:3000
