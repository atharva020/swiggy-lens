# Anthropic (required for insight cards)
ANTHROPIC_API_KEY=

# Swiggy OAuth — optional: DCR registers a client automatically on Connect.
# Set these only if Swiggy issued you a static client (production / enterprise).
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=
SWIGGY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Dev-only: skip OAuth and inject a Bearer token from a completed OAuth flow.
# Must be the access_token JWT from POST /auth/token — not an API key.
SWIGGY_ACCESS_TOKEN=

# Session encryption (min 32 random characters; required in production)
SESSION_SECRET=

# App base URL (must match redirect URI host)
NEXTAUTH_URL=http://localhost:3000
