# ─── LLM Provider ─────────────────────────────────────────────────
# Set ONE of these. The app auto-detects which provider to use.
# If both are set, OPENAI_API_KEY takes priority (override with LLM_PROVIDER).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: force a specific provider ("openai" or "anthropic")
# LLM_PROVIDER=openai

# Optional: override the model name
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Swiggy OAuth ────────────────────────────────────────────────
# Dynamic Client Registration handles client_id automatically.
# Set these only if Swiggy issued you a static client (production).
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=
SWIGGY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Dev-only ────────────────────────────────────────────────────
# Skip OAuth and inject a Bearer token from a completed OAuth flow.
# Must be the access_token JWT from POST /auth/token — not an API key.
SWIGGY_ACCESS_TOKEN=

# ─── Session ─────────────────────────────────────────────────────
# Encrypts cookies. Min 32 random chars. Required in production.
SESSION_SECRET=

# ─── App ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
